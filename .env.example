# AI Trader Backend Environment
# Copy this file to .env and fill in the blank values.
# Never commit .env.

# Runtime
NODE_ENV=development
PORT=3000

# Database
# Local Docker Compose default:
DATABASE_URL="postgresql://trader:traderpass@localhost:5432/ai_trader"

# Alpaca Trading API
# Paper base URL: https://paper-api.alpaca.markets
# Live base URL:  https://api.alpaca.markets
ALPACA_API_KEY=
ALPACA_API_SECRET=
ALPACA_BASE_URL=https://paper-api.alpaca.markets
ALPACA_API_USAGE_WARNING_REQUESTS_PER_MINUTE=120
ALPACA_API_USAGE_RETENTION_DAYS=30

# Default TradingAccount used by the current single-account runtime.
# Bobby Paper production uses id=1 and falls back to the legacy ALPACA_* env vars
# unless an ACTIVE TradingAccountCredential exists for the account.
DEFAULT_TRADING_ACCOUNT_ID=1

# Trading account credential encryption
# Used to encrypt broker API credentials before storing them in the database.
# Generate with: openssl rand -base64 32
TRADING_CREDENTIAL_ENCRYPTION_KEY=replace_with_base64_32_byte_key
# Identifier stored in encrypted credential payloads for future key rotation.
TRADING_CREDENTIAL_ENCRYPTION_KEY_ID=local-v1

# Massive API (for market data and sentiment analysis)
MASSIVE_API_KEY=your_new_key_here
MASSIVE_BASE_URL=https://api.massive.com

# AI Trader API Keys
# These are sent by trusted automation / maintenance clients in the ai-trader-api-key header.
# Generate long random values for each environment.
# The signal key is for n8n / signal routes.
# The admin key is for Postman / maintenance access and can also access signal routes.
AI_TRADER_SIGNAL_API_KEY=
AI_TRADER_ADMIN_API_KEY=

# Production safety overrides
# Keep both false for first production launch.
ALLOW_LIVE_TRADING=false
# Required only when intentionally restarting production in live mode with tradingEnabled=true. This prevents accidental live trading on startup.
ALLOW_TRADING_ENABLED_ON_START=false

# CORS
# Comma-separated list of browser origins allowed to call the backend.
# Development examples:
#   http://localhost:5173,http://localhost:4173
# Production example:
#   https://admin.your-domain.com
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:4173

# Development tunnel only
# Required only if using ngrok locally.
NGROK_AUTHTOKEN=
NGROK_DOMAIN=
