generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Setting {
  id        Int      @id @default(autoincrement())
  key       String   @unique
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AdminUser {
  id           Int      @id @default(autoincrement())
  email        String   @unique
  passwordHash String
  role         String   @default("admin")
  enabled      Boolean  @default(true)

  lastLoginAt  DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  sessions     AdminSession[]
}

model AdminSession {
  id          Int       @id @default(autoincrement())
  adminUserId Int
  tokenHash   String    @unique

  userAgent   String?
  ipAddress   String?

  expiresAt   DateTime
  revokedAt   DateTime?
  lastSeenAt  DateTime  @default(now())

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  adminUser   AdminUser @relation(fields: [adminUserId], references: [id])

  @@index([adminUserId])
  @@index([expiresAt])
  @@index([revokedAt])
}

model AllowedTicker {
  id     Int    @id @default(autoincrement())
  symbol String @unique
}

model OrderIntent {
  id             Int      @id @default(autoincrement())
  source         String
  symbol         String
  side           String
  orderType      String
  timeInForce    String
  qty            Float?
  notional       Float?
  limitPrice     Float?
  extendedHours  Boolean  @default(false)
  clientOrderId  String?
  status         String   @default("received")
  blockReason    String?
  rawRequestJson Json
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  subscriptionId    Int?
  subscriptionKey   String?
  subscription      Subscription? @relation(fields: [subscriptionId], references: [id])

  brokerOrders   BrokerOrder[]
}

model BrokerOrder {
  id             Int      @id @default(autoincrement())
  orderIntentId  Int
  broker         String
  brokerOrderId  String
  clientOrderId  String
  symbol         String
  side           String
  status         String
  rawBrokerJson  Json
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  orderIntent    OrderIntent @relation(fields: [orderIntentId], references: [id])
}

model SystemEvent {
  id          Int      @id @default(autoincrement())
  type        String
  entityType  String
  entityId    String
  payloadJson Json
  processed   Boolean  @default(false)
  createdAt   DateTime @default(now())
}

model TrackedPosition {
  id                  Int      @id @default(autoincrement())
  broker              String
  symbol              String   @unique
  side                String
  qty                 Float
  avgEntryPrice       Float
  currentPrice        Float
  marketValue         Float
  costBasis           Float
  unrealizedPnL       Float
  unrealizedPnLPct    Float
  status              String    @default("open")
  openedAt            DateTime  @default(now())
  lastSyncedAt        DateTime  @default(now())
  closedAt            DateTime?
  rawPositionJson     Json
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  subscriptionId      Int?
  subscription        Subscription?   @relation(fields: [subscriptionId], references: [id])
}

model Strategy {
  id                 Int            @id @default(autoincrement())
  key                String         @unique
  name               String
  description        String?
  allowedSymbolsJson Json?
  enabled            Boolean        @default(true)
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt

  subscriptions      Subscription[]
}

model ExitProfile {
  id                 Int            @id @default(autoincrement())
  key                String         @unique
  name               String
  description        String?
  targetPct          Float?
  stopLossPct        Float?
  trailingStopPct    Float?
  maxHoldDays        Int?
  exitMode           String
  takeProfitBehavior String
  enabled            Boolean        @default(true)
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt

  subscriptions      Subscription[]
}

model Subscription {
  id             Int         @id @default(autoincrement())
  key            String      @unique
  name           String
  symbol         String
  broker         String      @default("alpaca")
  brokerMode     String      @default("paper")
  sizingType     String
  sizingValue    Float
  enabled        Boolean     @default(true)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  strategyId     Int
  exitProfileId  Int

  strategy       Strategy    @relation(fields: [strategyId], references: [id])
  exitProfile    ExitProfile @relation(fields: [exitProfileId], references: [id])

  trackedPositions    TrackedPosition[]
  orderIntents        OrderIntent[]

  @@index([symbol])
  @@index([strategyId])
  @@index([exitProfileId])
}