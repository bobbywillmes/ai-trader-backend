generator client {
  provider = "prisma-client-js"
}

generator dbml {
  provider            = "prisma-dbml-generator"
  output              = "../docs/database"
  outputName          = "ai-trader.dbml"
  projectName         = "AI Trader Backend"
  projectDatabaseType = "PostgreSQL"
  projectNote         = "Generated from prisma/schema.prisma. Do not edit manually."
}

datasource db {
  provider = "postgresql"
}

model Setting {
  id        Int      @id @default(autoincrement())
  key       String   @unique
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AdminUser {
  id           Int     @id @default(autoincrement())

  email        String  @unique
  passwordHash String
  role         String  @default("admin")
  enabled      Boolean @default(true)

  name              String?
  emailVerifiedAt   DateTime?

  lastLoginAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  sessions AdminSession[]

  ownedTradingAccounts  TradingAccount[] @relation("TradingAccountOwner")
  tradingAccountAccess  TradingAccountAccess[]
}

model AdminSession {
  id          Int    @id @default(autoincrement())
  adminUserId Int
  tokenHash   String @unique

  userAgent String?
  ipAddress String?

  expiresAt  DateTime
  revokedAt  DateTime?
  lastSeenAt DateTime  @default(now())

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  adminUser AdminUser @relation(fields: [adminUserId], references: [id])

  @@index([adminUserId])
  @@index([expiresAt])
  @@index([revokedAt])
}

enum TradingBroker {
  ALPACA
}

enum TradingAccountEnvironment {
  PAPER
  LIVE
}

enum TradingAccountStatus {
  NEEDS_CREDENTIALS
  ACTIVE
  PAUSED
  DISABLED
  ERROR
}

enum PositionSizingType {
  FIXED_QTY
  MAX_NOTIONAL
}

model TradingAccount {
  id                        Int @id @default(autoincrement())

  ownerAdminUserId          Int
  ownerAdminUser            AdminUser @relation("TradingAccountOwner", fields: [ownerAdminUserId], references: [id])

  displayName               String

  broker                    TradingBroker @default(ALPACA)
  environment               TradingAccountEnvironment @default(PAPER)
  status                    TradingAccountStatus @default(NEEDS_CREDENTIALS)

  tradingEnabled            Boolean @default(false)
  killSwitchEnabled         Boolean @default(true)

  estimatedTradingCapital   Float?
  baseCurrency              String @default("USD")

  brokerAccountId           String?
  brokerAccountNumberMasked String?
  brokerAccountStatus       String?

  lastBrokerSyncAt          DateTime?
  lastCash                  Float?
  lastBuyingPower           Float?
  lastEquity                Float?
  lastPortfolioValue        Float?
  tradingBlocked            Boolean?

  pausedReason              String?
  notes                     String?

  credential                TradingAccountCredential?
  riskSettings              TradingAccountRiskSettings?
  access                    TradingAccountAccess[]

  // Future/current trading relations
  subscriptions             Subscription[]
  allocations               TradingAccountAllocation[]
  accountSubscriptions      TradingAccountSubscription[]
  orderIntents              OrderIntent[]
  brokerOrders              BrokerOrder[]
  brokerActivities          BrokerActivity[]
  trackedPositions          TrackedPosition[]
  accountSnapshots          AccountSnapshot[]
  entryDecisions            EntryDecision[]
  systemEvents              SystemEvent[]
  alpacaApiUsageBuckets     AlpacaApiUsageBucket[]

  createdAt                 DateTime @default(now())
  updatedAt                 DateTime @updatedAt

  @@index([ownerAdminUserId])
  @@index([broker, environment])
  @@index([status])
  @@index([tradingEnabled])
  @@index([killSwitchEnabled])
  @@unique([broker, environment, brokerAccountId])
}

model TradingAccountRiskSettings {
  id                                  Int @id @default(autoincrement())

  tradingAccountId                    Int @unique
  tradingAccount                      TradingAccount @relation(fields: [tradingAccountId], references: [id], onDelete: Cascade)

  enabled                             Boolean @default(true)

  maxDailyEntryOrders                 Int?
  maxDailyEntryNotional               Float?
  maxOpenPositions                    Int?
  maxTotalOpenNotional                Float?
  maxSymbolOpenNotional               Float?
  maxSubscriptionOpenNotional         Float?

  notes                               String?

  createdAt                           DateTime @default(now())
  updatedAt                           DateTime @updatedAt

  @@index([enabled])
}

enum BrokerCredentialAuthType {
  API_KEY
  OAUTH
}

enum BrokerCredentialStatus {
  NEEDS_VERIFICATION
  ACTIVE
  INVALID
  REVOKED
}

model TradingAccountCredential {
  id                      Int @id @default(autoincrement())

  tradingAccountId        Int @unique
  tradingAccount          TradingAccount @relation(fields: [tradingAccountId], references: [id], onDelete: Cascade)

  authType                BrokerCredentialAuthType @default(API_KEY)
  status                  BrokerCredentialStatus @default(NEEDS_VERIFICATION)

  apiKeyCiphertext        String?
  apiSecretCiphertext     String?

  accessTokenCiphertext   String?
  refreshTokenCiphertext  String?

  keyFingerprint          String?
  encryptionVersion       Int @default(1)

  verifiedAt              DateTime?
  lastUsedAt              DateTime?
  lastFailedAt            DateTime?
  revokedAt               DateTime?

  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  @@index([status])
}

enum TradingAccountAccessRole {
  OWNER
  MANAGER
  VIEWER
}

model TradingAccountAccess {
  id                        Int @id @default(autoincrement())

  tradingAccountId          Int
  tradingAccount            TradingAccount @relation(fields: [tradingAccountId], references: [id], onDelete: Cascade)

  adminUserId               Int
  adminUser                 AdminUser @relation(fields: [adminUserId], references: [id], onDelete: Cascade)

  role                      TradingAccountAccessRole

  canView                   Boolean @default(true)
  canPauseTrading           Boolean @default(false)
  canResumeTrading          Boolean @default(false)
  canEditRiskSettings       Boolean @default(false)
  canEditStrategySettings   Boolean @default(false)
  canEditCredentials        Boolean @default(false)
  canManageAccess           Boolean @default(false)

  createdAt                 DateTime @default(now())
  updatedAt                 DateTime @updatedAt

  @@unique([tradingAccountId, adminUserId])
  @@index([adminUserId])
  @@index([tradingAccountId])
  @@index([role])
}

model TradingAccountAllocation {
  id                      Int @id @default(autoincrement())

  tradingAccountId        Int
  tradingAccount          TradingAccount @relation(fields: [tradingAccountId], references: [id], onDelete: Cascade)

  key                     String
  name                    String
  description             String?

  enabled                 Boolean @default(true)

  // Total dollars allowed/reserved for this allocation bucket.
  // Optional for the foundation migration so existing data can be backfilled safely.
  maxAllocatedNotional    Float?

  // Useful for shared buckets like momentum.
  maxOpenPositions        Int?

  // Optional default per-position cap for subscriptions assigned to this bucket.
  // TradingAccountSubscription.maxPositionNotional can override this.
  maxPositionNotional     Float?

  notes String?

  accountSubscriptions    TradingAccountSubscription[]

  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  @@unique([tradingAccountId, key])
  @@index([tradingAccountId])
  @@index([enabled])
}

model TradingAccountSubscription {
  id Int @id @default(autoincrement())

  tradingAccountId      Int
  tradingAccount        TradingAccount @relation(fields: [tradingAccountId], references: [id], onDelete: Cascade)

  subscriptionId        Int
  subscription          Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  allocationId          Int?
  allocation            TradingAccountAllocation? @relation(fields: [allocationId], references: [id], onDelete: SetNull)

  // Master account-subscription switch.
  enabled               Boolean @default(true)

  // Operational switches.
  entriesEnabled        Boolean @default(true)
  exitsEnabled          Boolean @default(true)

  sizingType            PositionSizingType @default(FIXED_QTY)

  // Used when sizingType = FIXED_QTY.
  fixedQty              Float?

  // Used when sizingType = MAX_NOTIONAL.
  maxPositionNotional   Float?

  // Optional guardrails.
  minPositionNotional   Float?
  maxQty                Float?

  notes String?

  orderIntents          OrderIntent[]
  trackedPositions      TrackedPosition[]
  entryDecisions        EntryDecision[]

  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@unique([tradingAccountId, subscriptionId])
  @@index([tradingAccountId])
  @@index([subscriptionId])
  @@index([allocationId])
  @@index([enabled])
  @@index([entriesEnabled])
  @@index([exitsEnabled])
  @@index([tradingAccountId, enabled])
  @@index([tradingAccountId, entriesEnabled])
  @@index([tradingAccountId, exitsEnabled])
  @@index([allocationId, enabled])
}

enum AssetType {
  STOCK
  ETF
  INDEX
  FUND
  OTHER
}

model Security {
  id        Int       @id @default(autoincrement())
  symbol    String    @unique
  name      String
  enabled   Boolean   @default(true)
  assetType AssetType
  sector    String?
  industry  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  subscriptions    Subscription[]
  trackedPositions TrackedPosition[]
  brokerOrders     BrokerOrder[]
  entryDecisions   EntryDecision[]

  @@index([enabled])
  @@index([assetType])
}

model OrderIntent {
  id             Int      @id @default(autoincrement())
  source         String
  symbol         String
  side           String
  orderType      String
  timeInForce    String
  qty            Float?
  notional       Float?
  limitPrice     Float?
  extendedHours  Boolean  @default(false)
  clientOrderId  String?
  status         String   @default("received")
  blockReason    String?
  rawRequestJson Json
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  subscriptionId  Int?
  subscriptionKey String?
  subscription    Subscription? @relation(fields: [subscriptionId], references: [id])

  trackedPositionId Int?
  trackedPosition   TrackedPosition? @relation(fields: [trackedPositionId], references: [id], onDelete: SetNull)

  tradingAccountId  Int?
  tradingAccount    TradingAccount? @relation(fields: [tradingAccountId], references: [id], onDelete: SetNull)

  tradingAccountSubscriptionId      Int?
  tradingAccountSubscription        TradingAccountSubscription? @relation(fields: [tradingAccountSubscriptionId], references: [id], onDelete: SetNull)

  brokerOrders     BrokerOrder[]
  brokerActivities BrokerActivity[]
  entryDecision    EntryDecision?

  @@index([trackedPositionId])
  @@index([tradingAccountId])
  @@index([tradingAccountId, status])
  @@index([tradingAccountId, createdAt])
  @@index([tradingAccountSubscriptionId])
  @@index([tradingAccountId, tradingAccountSubscriptionId])
  @@index([tradingAccountSubscriptionId, createdAt])
}

model BrokerOrder {
  id            Int      @id @default(autoincrement())
  orderIntentId Int
  broker        String
  brokerOrderId String
  clientOrderId String
  symbol        String
  side          String
  status        String
  rawBrokerJson Json
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  securityId Int
  security   Security @relation(fields: [securityId], references: [id])

  orderIntent OrderIntent @relation(fields: [orderIntentId], references: [id])

  trackedPositionId Int?
  trackedPosition   TrackedPosition? @relation(fields: [trackedPositionId], references: [id], onDelete: SetNull)

  tradingAccountId  Int?
  tradingAccount    TradingAccount? @relation(fields: [tradingAccountId], references: [id], onDelete: SetNull)

  brokerActivities BrokerActivity[]
  entryDecision    EntryDecision?

  @@unique([broker, brokerOrderId])
  @@unique([broker, clientOrderId])
  @@index([trackedPositionId])
  @@index([tradingAccountId])
  @@index([tradingAccountId, status])
  @@index([tradingAccountId, symbol])
}

model SystemEvent {
  id          Int      @id @default(autoincrement())
  type        String
  entityType  String
  entityId    String
  message     String?
  payloadJson Json
  processed   Boolean  @default(false)
  createdAt   DateTime @default(now())
  tradingAccountId  Int?
  tradingAccount    TradingAccount? @relation(fields: [tradingAccountId], references: [id], onDelete: SetNull)

  @@index([tradingAccountId])
  @@index([tradingAccountId, createdAt])
}

model WorkerHealthState {
  id                  Int       @id @default(autoincrement())
  key                 String    @unique
  processInstanceId   String
  enabled             Boolean
  expectedIntervalMs  Int
  currentRunStartedAt DateTime?
  lastTickStartedAt   DateTime?
  lastTickCompletedAt DateTime?
  lastSucceededAt     DateTime?
  lastWorkSucceededAt DateTime?
  lastFailedAt        DateTime?
  lastDurationMs      Int?
  lastOutcome         String?
  lastSkipReason      String?
  consecutiveFailures Int       @default(0)
  totalRuns           Int       @default(0)
  totalFailures       Int       @default(0)
  totalSkips          Int       @default(0)
  lastError           String?
  lastErrorAt         DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  @@index([processInstanceId])
  @@index([updatedAt])
  @@index([enabled])
}

model AlpacaApiUsageBucket {
  id                Int       @id @default(autoincrement())
  bucketStart       DateTime
  bucketSizeMinutes Int
  operation         String
  endpoint          String
  method            String
  requestClass      String
  requestCount      Int       @default(0)
  successCount      Int       @default(0)
  failureCount      Int       @default(0)
  rateLimitCount    Int       @default(0)
  networkErrorCount Int       @default(0)
  totalDurationMs   Int       @default(0)
  maxDurationMs     Int       @default(0)
  lastStatusCode    Int?
  lastRequestAt     DateTime?
  lastFailureAt     DateTime?
  lastRateLimitedAt DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  tradingAccountId  Int?
  tradingAccount    TradingAccount? @relation(fields: [tradingAccountId], references: [id], onDelete: SetNull)

  @@unique([bucketStart, operation, endpoint, method, requestClass])
  @@index([bucketStart])
  @@index([operation])
  @@index([endpoint])
  @@index([updatedAt])
  @@index([tradingAccountId])
  @@index([tradingAccountId, bucketStart])
  @@index([tradingAccountId, updatedAt])
}

model CurrentMarketState {
  id Int @id

  marketBias String @default("neutral")
  riskMode   String @default("normal")

  macroSummary String?
  watchFor     String?
  avoidBecause String?
  notes        String?

  source       String    @default("system")
  validUntil   DateTime?
  lastLlmRunAt DateTime?

  payloadJson Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model MarketDiaryEvent {
  id Int @id @default(autoincrement())

  eventType String
  source    String  @default("system")
  symbol    String?

  summary String
  details String?

  symbolsJson Json?
  payloadJson Json?

  createdAt DateTime @default(now())

  @@index([eventType])
  @@index([source])
  @@index([symbol])
  @@index([createdAt])
}

enum CatalystSource {
  MASSIVE_NEWS
  MASSIVE_BENZINGA
  SEC_EDGAR
  COMPANY_IR
  MANUAL
}

enum CatalystEventType {
  EARNINGS
  GUIDANCE
  ANALYST_UPGRADE
  ANALYST_DOWNGRADE
  FDA_REGULATORY
  CONTRACT_WIN
  PARTNERSHIP
  ACQUISITION_MERGER
  INDEX_ADDITION
  INDEX_REMOVAL
  INSIDER_BUYING
  INSIDER_SELLING
  OFFERING_DILUTION
  SEC_FILING
  PRODUCT_LAUNCH
  MACRO_MARKET
  SECTOR_THEME
  OPINION_ANALYSIS
  UNKNOWN
}

enum CatalystTier {
  HIGH
  MEDIUM
  LOW
  IGNORE
}

enum CatalystSentiment {
  POSITIVE
  NEGATIVE
  NEUTRAL
  MIXED
  UNKNOWN
}

enum CatalystTickerRole {
  PRIMARY_SUBJECT
  DIRECT_BENEFICIARY
  INDIRECT_BENEFICIARY
  DIRECT_NEGATIVE
  INDIRECT_NEGATIVE
  PEER_COMPARISON
  CUSTOMER
  SUPPLIER
  COMPETITOR
  TANGENTIAL_MENTION
}

model CatalystEvent {
  id               String @id @default(cuid())

  source           CatalystSource
  sourceExternalId String?
  sourceUrl        String?
  sourcePublisher  String?
  sourceAuthor     String?

  title            String
  summary          String?
  bodyExcerpt      String?
  language         String?

  publishedAt      DateTime?
  receivedAt       DateTime @default(now())

  eventType        CatalystEventType @default(UNKNOWN)
  eventTier        CatalystTier      @default(LOW)
  sentiment        CatalystSentiment @default(UNKNOWN)
  confidence       Float?

  isDuplicate      Boolean @default(false)
  duplicateOfId    String?

  rawPayload       Json?
  metadata         Json?

  tickerImpacts    CatalystTickerImpact[]

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@unique([source, sourceExternalId])
  @@index([source, publishedAt])
  @@index([eventType, eventTier])
  @@index([receivedAt])
}

model CatalystTickerImpact {
  id                 String @id @default(cuid())

  catalystEventId    String
  catalystEvent      CatalystEvent @relation(fields: [catalystEventId], references: [id], onDelete: Cascade)

  symbol             String

  sentiment          CatalystSentiment @default(UNKNOWN)
  sentimentReasoning String?

  relevanceScore     Int @default(0)
  actionabilityScore Int @default(0)
  freshnessScore     Int @default(0)
  sourceQualityScore Int @default(0)
  totalCatalystScore Int @default(0)

  isPrimaryTicker    Boolean @default(false)
  isCompanySpecific  Boolean @default(false)
  isMarketWide       Boolean @default(false)
  isSectorWide       Boolean @default(false)

  catalystRole       CatalystTickerRole?
  blockedReason      String?

  rawInsight         Json?
  metadata           Json?

  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@unique([catalystEventId, symbol])
  @@index([symbol, totalCatalystScore])
  @@index([symbol, createdAt])
  @@index([totalCatalystScore])
}

model NewsPullCursor {
  id                String @id @default(cuid())

  source            CatalystSource
  symbol            String

  enabled           Boolean @default(true)
  priority          Int     @default(0)

  pullIntervalMin   Int     @default(15)
  lastPulledAt      DateTime?
  lastPublishedAt   DateTime?
  lastSourceCursor  String?

  consecutiveErrors Int     @default(0)
  lastError         String?

  metadata          Json?

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@unique([source, symbol])
  @@index([enabled, priority, lastPulledAt])
  @@index([source, enabled])
  @@index([symbol])
}

model EntryDecision {
  id                      Int      @id @default(autoincrement())
  decisionKey             String   @unique
  evaluatedAt             DateTime
  source                  String
  symbol                  String

  decisionState           String
  decisionReason          String?

  signalAction            String?
  signalEligible          Boolean?
  signalCreated           Boolean  @default(false)
  signalBlocked           Boolean  @default(false)
  blockingReason          String?

  currentPrice            Float?
  previousClose           Float?
  dayLow                  Float?
  dayChangePercent        Float?
  dipPercent              Float?
  dipThresholdPercent     Float?
  retraceFraction         Float?

  cooldownActive          Boolean?
  cooldownUntil           DateTime?
  minutesSinceLastSignal  Float?
  allowOrderSignals       Boolean?
  dryRun                  Boolean?
  eventRisk               String?
  marketSession           String?
  tradingEnabled          Boolean?
  killSwitchEnabled       Boolean?
  paperMode               Boolean?

  persistenceReason       String
  decisionFingerprint     String

  marketSnapshotJson      Json?
  runtimeSnapshotJson     Json?
  strategySnapshotJson    Json?
  indicatorSnapshotJson   Json?
  rawDecisionJson         Json

  securityId              Int?
  security                Security? @relation(fields: [securityId], references: [id], onDelete: SetNull)

  subscriptionId          Int?
  subscriptionKey         String?
  subscription            Subscription? @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)

  strategyId              Int?
  strategyKey             String?
  strategy                Strategy? @relation(fields: [strategyId], references: [id], onDelete: SetNull)

  exitProfileId           Int?
  exitProfileKey          String?
  exitProfile             ExitProfile? @relation(fields: [exitProfileId], references: [id], onDelete: SetNull)

  orderIntentId           Int?         @unique
  orderIntent             OrderIntent? @relation(fields: [orderIntentId], references: [id], onDelete: SetNull)

  brokerOrderRecordId     Int?         @unique
  brokerOrderRecord       BrokerOrder? @relation(fields: [brokerOrderRecordId], references: [id], onDelete: SetNull)

  trackedPositionId       Int?             @unique
  trackedPosition         TrackedPosition? @relation(fields: [trackedPositionId], references: [id], onDelete: SetNull)

  tradingAccountId        Int?
  tradingAccount          TradingAccount? @relation(fields: [tradingAccountId], references: [id], onDelete: SetNull)

  tradingAccountSubscriptionId    Int?
  tradingAccountSubscription      TradingAccountSubscription? @relation(fields: [tradingAccountSubscriptionId], references: [id], onDelete: SetNull)

  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  @@index([evaluatedAt])
  @@index([symbol, evaluatedAt])
  @@index([decisionState, evaluatedAt])
  @@index([subscriptionId, evaluatedAt])
  @@index([strategyId, evaluatedAt])
  @@index([exitProfileId, evaluatedAt])
  @@index([securityId])
  @@index([tradingAccountId])
  @@index([tradingAccountId, evaluatedAt])
  @@index([tradingAccountId, symbol, evaluatedAt])
  @@index([tradingAccountSubscriptionId])
  @@index([tradingAccountId, tradingAccountSubscriptionId])
  @@index([tradingAccountSubscriptionId, evaluatedAt])
}

model TrackedPosition {
  id               Int       @id @default(autoincrement())
  broker           String
  symbol           String
  side             String
  qty              Float
  avgEntryPrice    Float
  currentPrice     Float
  marketValue      Float
  costBasis        Float
  unrealizedPnL    Float
  unrealizedPnLPct Float
  status           String    @default("open")
  openedAt         DateTime  @default(now())
  lastSyncedAt     DateTime  @default(now())
  closedAt         DateTime?
  rawPositionJson  Json
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  securityId Int
  security   Security @relation(fields: [securityId], references: [id])

  subscriptionId Int?
  subscription   Subscription? @relation(fields: [subscriptionId], references: [id])

  orderIntents     OrderIntent[]
  brokerOrders     BrokerOrder[]
  brokerActivities BrokerActivity[]
  entryDecision    EntryDecision?

  exitState PositionExitState?

  configSnapshotJson       Json?
  configSnapshotCapturedAt DateTime?

  tradingAccountId        Int?
  tradingAccount          TradingAccount? @relation(fields: [tradingAccountId], references: [id], onDelete: SetNull)

  tradingAccountSubscriptionId    Int?
  tradingAccountSubscription      TradingAccountSubscription? @relation(fields: [tradingAccountSubscriptionId], references: [id], onDelete: SetNull)

  // Unlock trailing-stop state
  trailingUnlocked      Boolean   @default(false)
  trailingUnlockedAt    DateTime?
  trailingUnlockedPrice Float?

  // Native broker trailing-stop order state
  trailingStopOrderId       String?
  trailingStopClientOrderId String?
  trailingStopSubmittedAt   DateTime?
  trailingStopStatus        String?

  // Latest broker-reported trailing-stop values
  trailingStopTrailPercent Float?
  trailingStopHwm          Float?
  trailingStopStopPrice    Float?
  trailingStopLastSyncedAt DateTime?

  @@index([broker, symbol])
  @@index([broker, symbol, status])
  @@index([subscriptionId])
  @@index([trailingStopOrderId])
  @@index([trailingStopStatus])
  @@index([tradingAccountId])
  @@index([tradingAccountId, status])
  @@index([tradingAccountId, symbol])
  @@index([tradingAccountId, symbol, status])
  @@index([tradingAccountSubscriptionId])
  @@index([tradingAccountId, tradingAccountSubscriptionId])
  @@index([tradingAccountSubscriptionId, status])
}

model PositionExitState {
  id                Int @id @default(autoincrement())
  trackedPositionId Int @unique

  status               String    @default("watching")
  targetUnlocked       Boolean   @default(false)
  targetUnlockedAt     DateTime?
  targetUnlockedPrice  Float?
  targetUnlockedPnlPct Float?

  highWaterMark  Float?
  trailStopPrice Float?

  exitProfileKey     String?
  exitMode           String?
  takeProfitBehavior String?
  targetPct          Float?
  trailingStopPct    Float?

  trailBroker        String?
  trailBrokerOrderId String?
  trailClientOrderId String?
  trailOrderStatus   String?
  rawBrokerJson      Json?

  // Human/operator attention state
  attentionRequired  Boolean   @default(false)
  attentionCode      String?
  attentionMessage   String?
  attentionAt        DateTime?
  attentionClearedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  trackedPosition TrackedPosition @relation(fields: [trackedPositionId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([targetUnlocked])
  @@index([trailOrderStatus])
  @@index([attentionRequired])
  @@index([attentionCode])
}

model AccountSnapshot {
  id Int @id @default(autoincrement())

  broker        String
  mode          String
  accountStatus String?
  currency      String?
  accountNumber String?

  reason           String
  runKey           String? @unique
  sourceEntityType String?
  sourceEntityId   String?

  cash             Float
  buyingPower      Float
  equity           Float
  portfolioValue   Float
  lastEquity       Float?
  longMarketValue  Float?
  shortMarketValue Float?
  dayPnL           Float?
  dayPnLPct        Float?
  tradingBlocked   Boolean

  tradingAccountId  Int?
  tradingAccount    TradingAccount? @relation(fields: [tradingAccountId], references: [id], onDelete: SetNull)

  snapshotHash String
  changed      Boolean @default(true)

  rawJson   Json
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([reason])
  @@index([broker, mode])
  @@index([changed])
  @@index([tradingAccountId])
  @@index([tradingAccountId, createdAt])
  @@index([tradingAccountId, reason])
}

model BrokerActivity {
  id Int @id @default(autoincrement())

  broker String
  mode   String

  activityId       String  @unique
  activityType     String
  activityCategory String?

  symbol String?
  side   String?

  qty       Float?
  cumQty    Float?
  leavesQty Float?
  price     Float?
  netAmount Float?

  orderId                   String?
  orderIntentId             Int?
  brokerOrderRecordId       Int?
  trackedPositionId         Int?
  trackedPositionLinkSource String?
  trackedPositionLinkedAt   DateTime?

  transactionTime DateTime?
  rawBrokerJson   Json

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  orderIntent       OrderIntent?     @relation(fields: [orderIntentId], references: [id])
  brokerOrderRecord BrokerOrder?     @relation(fields: [brokerOrderRecordId], references: [id])
  trackedPosition   TrackedPosition? @relation(fields: [trackedPositionId], references: [id], onDelete: SetNull)

  tradingAccountId  Int?
  tradingAccount    TradingAccount? @relation(fields: [tradingAccountId], references: [id], onDelete: SetNull)

  @@index([activityType])
  @@index([symbol])
  @@index([side])
  @@index([orderId])
  @@index([transactionTime])
  @@index([orderIntentId])
  @@index([brokerOrderRecordId])
  @@index([trackedPositionId])
  @@index([trackedPositionLinkSource])
  @@index([broker, mode])
  @@index([tradingAccountId])
  @@index([tradingAccountId, transactionTime])
  @@index([tradingAccountId, symbol])
}

model Strategy {
  id                 Int      @id @default(autoincrement())
  key                String   @unique
  name               String
  description        String?
  allowedSymbolsJson Json?
  enabled            Boolean  @default(true)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  subscriptions  Subscription[]
  entryDecisions EntryDecision[]
}

model ExitProfile {
  id                 Int      @id @default(autoincrement())
  key                String   @unique
  name               String
  description        String?
  targetPct          Float?
  stopLossPct        Float?
  trailingStopPct    Float?
  maxHoldDays        Int?
  exitMode           String
  takeProfitBehavior String
  enabled            Boolean  @default(true)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  subscriptions  Subscription[]
  entryDecisions EntryDecision[]
}

model Subscription {
  id          Int      @id @default(autoincrement())
  key         String   @unique
  name        String
  symbol      String
  broker      String   @default("alpaca")
  brokerMode  String   @default("paper")
  sizingType  String
  sizingValue Float
  enabled     Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  strategyId    Int
  exitProfileId Int

  securityId Int
  security   Security @relation(fields: [securityId], references: [id])

  strategy    Strategy    @relation(fields: [strategyId], references: [id])
  exitProfile ExitProfile @relation(fields: [exitProfileId], references: [id])

  trackedPositions        TrackedPosition[]
  orderIntents            OrderIntent[]
  entryDecisions          EntryDecision[]
  accountSubscriptions    TradingAccountSubscription[]

  tradingAccountId  Int?
  tradingAccount    TradingAccount? @relation(fields: [tradingAccountId], references: [id], onDelete: SetNull)

  @@index([symbol])
  @@index([strategyId])
  @@index([exitProfileId])
  @@index([tradingAccountId])
  @@index([tradingAccountId, enabled])
  @@index([tradingAccountId, symbol])
}
