generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Setting {
  id        Int      @id @default(autoincrement())
  key       String   @unique
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AdminUser {
  id           Int      @id @default(autoincrement())
  email        String   @unique
  passwordHash String
  role         String   @default("admin")
  enabled      Boolean  @default(true)

  lastLoginAt  DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  sessions     AdminSession[]
}

model AdminSession {
  id          Int       @id @default(autoincrement())
  adminUserId Int
  tokenHash   String    @unique

  userAgent   String?
  ipAddress   String?

  expiresAt   DateTime
  revokedAt   DateTime?
  lastSeenAt  DateTime  @default(now())

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  adminUser   AdminUser @relation(fields: [adminUserId], references: [id])

  @@index([adminUserId])
  @@index([expiresAt])
  @@index([revokedAt])
}

enum AssetType {
  STOCK
  ETF
  INDEX
  FUND
  OTHER
}

model Security {
  id        Int       @id @default(autoincrement())
  symbol    String    @unique
  name      String
  enabled   Boolean   @default(true)
  assetType AssetType
  sector    String?
  industry  String?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  subscriptions    Subscription[]
  trackedPositions TrackedPosition[]
  brokerOrders     BrokerOrder[]

  @@index([enabled])
  @@index([assetType])
}

model OrderIntent {
  id             Int      @id @default(autoincrement())
  source         String
  symbol         String
  side           String
  orderType      String
  timeInForce    String
  qty            Float?
  notional       Float?
  limitPrice     Float?
  extendedHours  Boolean  @default(false)
  clientOrderId  String?
  status         String   @default("received")
  blockReason    String?
  rawRequestJson Json
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  subscriptionId    Int?
  subscriptionKey   String?
  subscription      Subscription? @relation(fields: [subscriptionId], references: [id])

  brokerOrders   BrokerOrder[]
  brokerActivities  BrokerActivity[]
}

model BrokerOrder {
  id             Int      @id @default(autoincrement())
  orderIntentId  Int
  broker         String
  brokerOrderId  String
  clientOrderId  String
  symbol         String
  side           String
  status         String
  rawBrokerJson  Json
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  securityId Int
  security   Security @relation(fields: [securityId], references: [id])

  orderIntent    OrderIntent @relation(fields: [orderIntentId], references: [id])

  brokerActivities BrokerActivity[]

  @@unique([broker, brokerOrderId])
  @@unique([broker, clientOrderId])
}

model SystemEvent {
  id          Int      @id @default(autoincrement())
  type        String
  entityType  String
  entityId    String
  message     String?
  payloadJson Json
  processed   Boolean  @default(false)
  createdAt   DateTime @default(now())
}

model TrackedPosition {
  id                  Int      @id @default(autoincrement())
  broker              String
  symbol              String
  side                String
  qty                 Float
  avgEntryPrice       Float
  currentPrice        Float
  marketValue         Float
  costBasis           Float
  unrealizedPnL       Float
  unrealizedPnLPct    Float
  status              String    @default("open")
  openedAt            DateTime  @default(now())
  lastSyncedAt        DateTime  @default(now())
  closedAt            DateTime?
  rawPositionJson     Json
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  securityId          Int
  security            Security @relation(fields: [securityId], references: [id])

  subscriptionId      Int?
  subscription        Subscription?   @relation(fields: [subscriptionId], references: [id])

  exitState           PositionExitState?

  @@index([broker, symbol])
  @@index([broker, symbol, status])
  @@index([subscriptionId])
}

model PositionExitState {
  id                      Int       @id @default(autoincrement())
  trackedPositionId       Int       @unique

  status                  String    @default("watching")
  targetUnlocked          Boolean   @default(false)
  targetUnlockedAt        DateTime?
  targetUnlockedPrice     Float?
  targetUnlockedPnlPct    Float?

  highWaterMark           Float?
  trailStopPrice          Float?

  exitProfileKey          String?
  exitMode                String?
  takeProfitBehavior      String?
  targetPct               Float?
  trailingStopPct         Float?

  trailBroker             String?
  trailBrokerOrderId      String?
  trailClientOrderId      String?
  trailOrderStatus        String?
  rawBrokerJson           Json?

  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  trackedPosition         TrackedPosition   @relation(fields: [trackedPositionId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([targetUnlocked])
  @@index([trailOrderStatus])
}

model AccountSnapshot {
  id               Int      @id @default(autoincrement())

  broker           String
  mode             String
  accountStatus    String?
  currency         String?
  accountNumber    String?

  reason           String
  runKey           String?  @unique
  sourceEntityType String?
  sourceEntityId   String?

  cash             Float
  buyingPower      Float
  equity           Float
  portfolioValue   Float
  lastEquity       Float?
  dayPnL           Float?
  dayPnLPct        Float?
  tradingBlocked   Boolean

  snapshotHash     String
  changed          Boolean  @default(true)

  rawJson          Json
  createdAt        DateTime @default(now())

  @@index([createdAt])
  @@index([reason])
  @@index([broker, mode])
  @@index([changed])
}

model BrokerActivity {
  id                    Int @id @default(autoincrement())

  broker                String
  mode                  String

  activityId            String @unique
  activityType          String
  activityCategory      String?

  symbol                String?
  side                  String?

  qty                   Float?
  cumQty                Float?
  leavesQty             Float?
  price                 Float?
  netAmount             Float?

  orderId               String?
  orderIntentId         Int?
  brokerOrderRecordId   Int?

  transactionTime       DateTime?
  rawBrokerJson         Json

  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  orderIntent           OrderIntent? @relation(fields: [orderIntentId], references: [id])
  brokerOrderRecord     BrokerOrder? @relation(fields: [brokerOrderRecordId], references: [id])

  @@index([activityType])
  @@index([symbol])
  @@index([side])
  @@index([orderId])
  @@index([transactionTime])
  @@index([orderIntentId])
  @@index([brokerOrderRecordId])
  @@index([broker, mode])
}

model Strategy {
  id                 Int            @id @default(autoincrement())
  key                String         @unique
  name               String
  description        String?
  allowedSymbolsJson Json?
  enabled            Boolean        @default(true)
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt

  subscriptions      Subscription[]
}

model ExitProfile {
  id                 Int            @id @default(autoincrement())
  key                String         @unique
  name               String
  description        String?
  targetPct          Float?
  stopLossPct        Float?
  trailingStopPct    Float?
  maxHoldDays        Int?
  exitMode           String
  takeProfitBehavior String
  enabled            Boolean        @default(true)
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt

  subscriptions      Subscription[]
}

model Subscription {
  id             Int         @id @default(autoincrement())
  key            String      @unique
  name           String
  symbol         String
  broker         String      @default("alpaca")
  brokerMode     String      @default("paper")
  sizingType     String
  sizingValue    Float
  enabled        Boolean     @default(true)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  strategyId     Int
  exitProfileId  Int

  securityId     Int
  security       Security @relation(fields: [securityId], references: [id])

  strategy       Strategy    @relation(fields: [strategyId], references: [id])
  exitProfile    ExitProfile @relation(fields: [exitProfileId], references: [id])

  trackedPositions    TrackedPosition[]
  orderIntents        OrderIntent[]

  @@index([symbol])
  @@index([strategyId])
  @@index([exitProfileId])
}