# AI Trader Backend Production Example
# Copy this to .env on the VPS.
# Never commit the real .env file.

# Runtime
NODE_ENV=production
PORT=3000

# Public API domain used by Caddy
API_DOMAIN=api.your-domain.com

# Database
POSTGRES_PASSWORD=replace_with_a_long_random_password

# Alpaca Paper Trading
ALPACA_API_KEY=
ALPACA_API_SECRET=
ALPACA_BASE_URL=https://paper-api.alpaca.markets
ALPACA_API_USAGE_WARNING_REQUESTS_PER_MINUTE=120
ALPACA_API_USAGE_RETENTION_DAYS=30

# Massive Market Data API
MASSIVE_API_KEY=
MASSIVE_BASE_URL=https://api.massive.com

# API Keys
# Use two different long random values.
AI_TRADER_SIGNAL_API_KEY=
AI_TRADER_ADMIN_API_KEY=

# Production safety overrides
ALLOW_LIVE_TRADING=false
ALLOW_TRADING_ENABLED_ON_START=false

# CORS
# Use the future deployed admin UI origin.
# Do not use localhost in production.
CORS_ALLOWED_ORIGINS=https://admin.your-domain.com

# Seed behavior
SEED_ALL_SECURITY_SUBSCRIPTIONS=false
