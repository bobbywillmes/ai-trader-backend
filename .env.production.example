# AI Trader Backend Production Example
# Copy this to .env on the VPS.
# Never commit the real .env file.

# Runtime
NODE_ENV=production
PORT=3000

# Public API domain used by Caddy
API_DOMAIN=api.your-domain.com

# Database
POSTGRES_PASSWORD=replace_with_a_long_random_password

# Alpaca Paper Trading
ALPACA_API_KEY=
ALPACA_API_SECRET=
ALPACA_BASE_URL=https://paper-api.alpaca.markets
ALPACA_API_USAGE_WARNING_REQUESTS_PER_MINUTE=120
ALPACA_API_USAGE_RETENTION_DAYS=30

# Default TradingAccount used by the current single-account runtime.
# Bobby Paper production uses id=1 and falls back to the legacy ALPACA_* env vars
# unless an ACTIVE TradingAccountCredential exists for the account.
DEFAULT_TRADING_ACCOUNT_ID=1

# Trading account credential encryption
# Used to encrypt broker API credentials before storing them in the database.
# Generate with: openssl rand -base64 32
TRADING_CREDENTIAL_ENCRYPTION_KEY=replace_with_base64_32_byte_key
# Identifier stored in encrypted credential payloads for future key rotation.
TRADING_CREDENTIAL_ENCRYPTION_KEY_ID=prod-v1

# Massive Market Data API
MASSIVE_API_KEY=
MASSIVE_BASE_URL=https://api.massive.com

# Massive news ingestion worker
# Keep disabled until the Phase 2 worker has been intentionally enabled.
MASSIVE_NEWS_WORKER_ENABLED=false
MASSIVE_NEWS_WORKER_INTERVAL_MS=60000
MASSIVE_NEWS_LOOKBACK_MINUTES=240
MASSIVE_NEWS_LIMIT_PER_SYMBOL=50
MASSIVE_NEWS_MAX_SYMBOLS_PER_RUN=5

# API Keys
# Use two different long random values.
AI_TRADER_SIGNAL_API_KEY=
AI_TRADER_ADMIN_API_KEY=

# Production safety overrides
ALLOW_LIVE_TRADING=false
ALLOW_TRADING_ENABLED_ON_START=false

# CORS
# Use the future deployed admin UI origin.
# Do not use localhost in production.
CORS_ALLOWED_ORIGINS=https://admin.your-domain.com

# Seed behavior
SEED_ALL_SECURITY_SUBSCRIPTIONS=false
